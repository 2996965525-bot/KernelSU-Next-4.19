CONFIG_ENV=config.env
#内核源地址
KERNEL_SOURCE=https://github.com/Xiaomi-pad-6-development/aospa_kernel_xiaomi_pipa
#分支
KERNEL_SOURCE_BRANCH=android13-4.19-kona
#内核配置文件
KERNEL_CONFIG=vendor/pipa_stock_defconfig

#使用Clang构建内核
USE_GCC=false

#启用lxc-docker支持
ENABLE_LXC=true

#KernelSU相关，默认开启
ENABLE_KERNELSU=true
ADD_OVERLAYFS_CONFIG=true

#非gki内核使用比如4.19
KERNELSU_TAG=v0.9.5

KERNEL_IMAGE_NAME=Image
ARCH=arm64

#Clang编译参数
EXTRA_CMDS:LD=ld.lld LLVM=1 LLVM_IAS=1

#关闭fstack-protector-strong
DISABLE_FST=true

#关闭LTO
DISABLE-LTO=true

#关闭CC_WERROR
DISABLE_CC_WERROR=true

#关闭ccache（避免兼容问题）
ENABLE_CCACHE=false

#DTBO image
NEED_DTBO=false

#Build boot images
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/tomxi1997/KernelSU-Next-Action/main/boot/boot.img

#关闭Kali Nethunter
ENABLE_NETHUNTER=false
ENABLE_KALI=false
KERNEL_VERSION=4.19
ENABLE_WIREGUARD=true

#关闭nethunter
ENABLE_NETHUNTER=false
